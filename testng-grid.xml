<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Lab11 Grid Suite" parallel="tests" thread-count="4">
    <test name="Chrome Smoke">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="vn.ktpm.lab11.tests.SmokeLoginPageTest"/>
        </classes>
    </test>
    <test name="Chrome Login With Secret">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="vn.ktpm.lab11.tests.LoginWithSecretTest"/>
        </classes>
    </test>
    <test name="Firefox Smoke">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="vn.ktpm.lab11.tests.SmokeLoginPageTest"/>
        </classes>
    </test>
    <test name="Firefox Login With Secret">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="vn.ktpm.lab11.tests.LoginWithSecretTest"/>
        </classes>
    </test>
</suite>
